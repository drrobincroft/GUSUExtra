end

function [S,rank]=TOPSIS(F,w)
R=F';
% TOPSIS
V=R.*w';
Aplus=max(V);
Aminus=min(V);
C=zeros(18,1);
for i=1:18
    dplus=sqrt(sum((V(i,:)-Aplus).^2));
    dminus=sqrt(sum((V(i,:)-Aminus).^2));
    C(i)=dminus/(dplus+dminus);
end

% Rank
[S,rank]=sort(C,'descend');
end

function [S,rank]=enTOPSIS(F)
% Entropy Weight
R=F';
P=R./sum(R);
D=zeros(12,1);
for j=1:12
    D(j)=1+(1/log(18))*sum(P(:,j).*log(P(:,j)+eps));
end
w=D./sum(D);

[S,rank]=TOPSIS(F,w);
end
